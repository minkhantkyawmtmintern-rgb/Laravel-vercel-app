{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "outputDirectory": "public",
    "functions":{
        "api/lambda.php":{
            "runtime":"vercel-php@0.9.0",
            "maxDuration": 30
        }
    },
    "rewrites":[
        {"source":"/(.*)","destination":"/api/lambda.php"}
    ]
}